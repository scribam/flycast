[submodule "core/deps/SDL"]
	path = core/deps/SDL
	url = https://github.com/libsdl-org/SDL.git
[submodule "external/dirent"]
	path = external/dirent
	url = https://github.com/tronkko/dirent.git
[submodule "external/glm"]
	path = external/glm
	url = https://github.com/g-truc/glm.git
[submodule "external/glslang"]
	path = external/glslang
	url = https://github.com/KhronosGroup/glslang.git
[submodule "external/googletest"]
	path = external/googletest
	url = https://github.com/google/googletest.git
[submodule "external/libchdr"]
	path = external/libchdr
	url = https://github.com/rtissera/libchdr.git
[submodule "external/libzip"]
	path = external/libzip
	url = https://github.com/nih-at/libzip.git
[submodule "external/miniupnp"]
	path = external/miniupnp
	url = https://github.com/miniupnp/miniupnp.git
[submodule "external/nowide"]
	path = external/nowide
	url = https://github.com/boostorg/nowide.git
	branch = standalone
[submodule "external/volk"]
	path = external/volk
	url = https://github.com/zeux/volk.git
[submodule "external/Vulkan-Headers"]
	path = external/Vulkan-Headers
	url = https://github.com/KhronosGroup/Vulkan-Headers.git
