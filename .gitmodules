[submodule "core/deps/libchdr"]
	path = core/deps/libchdr
	url = https://github.com/rtissera/libchdr.git
	ignore = dirty
[submodule "core/deps/breakpad"]
	path = core/deps/breakpad
	url = https://github.com/flyinghead/mingw-breakpad
[submodule "core/deps/oboe"]
	path = core/deps/oboe
	url = https://github.com/google/oboe.git
[submodule "core/deps/discord-rpc"]
	path = core/deps/discord-rpc
	url = https://github.com/flyinghead/discord-rpc
[submodule "core/deps/libadrenotools"]
	path = core/deps/libadrenotools
	url = https://github.com/bylaws/libadrenotools
[submodule "core/deps/rcheevos"]
	path = core/deps/rcheevos
	url = https://github.com/RetroAchievements/rcheevos.git
[submodule "external/AltKit"]
	path = external/AltKit
	url = https://github.com/rileytestut/AltKit.git
[submodule "external/ELFIO"]
	path = external/ELFIO
	url = https://github.com/serge1/ELFIO.git
[submodule "external/LuaBridge"]
	path = external/LuaBridge
	url = https://github.com/vinniefalco/LuaBridge.git
[submodule "external/SDL"]
	path = external/SDL
	url = https://github.com/libsdl-org/SDL.git
[submodule "external/Spout2"]
	path = external/Spout2
	url = https://github.com/leadedge/Spout2.git
[submodule "external/Syphon-Framework"]
	path = external/Syphon-Framework
	url = https://github.com/vkedwardli/Syphon-Framework.git
[submodule "external/Vulkan-Headers"]
	path = external/Vulkan-Headers
	url = https://github.com/KhronosGroup/Vulkan-Headers.git
[submodule "external/VulkanMemoryAllocator"]
	path = external/VulkanMemoryAllocator
	url = https://github.com/GPUOpen-LibrariesAndSDKs/VulkanMemoryAllocator.git
[submodule "external/dirent"]
	path = external/dirent
	url = https://github.com/tronkko/dirent.git
[submodule "external/glm"]
	path = external/glm
	url = https://github.com/g-truc/glm.git
[submodule "external/glslang"]
	path = external/glslang
	url = https://github.com/KhronosGroup/glslang.git
